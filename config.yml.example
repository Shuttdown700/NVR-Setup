# Frigate config template — seeded to config/config.yml by setup.sh on first run.
# {FRIGATE_RTSP_PASSWORD} is substituted at runtime by Frigate from the env var
# set in docker-compose.yml (which reads it from .env). No plaintext creds here.

mqtt:
  enabled: false

go2rtc:
  streams:
    living_room:
      - rtsp://admin:{FRIGATE_RTSP_PASSWORD}@10.0.0.122:554/h264Preview_01_main
    living_room_sub:
      - rtsp://admin:{FRIGATE_RTSP_PASSWORD}@10.0.0.122:554/h264Preview_01_sub

detectors:
  cpu:
    type: cpu

# NOTE: no ffmpeg.hwaccel_args on purpose. preset-rpi-64-h264 targets the
# Pi 4's V4L2 M2M decoder (/dev/video11 / h264_v4l2m2m); the Pi 5 has no
# H.264 hardware decode block, so that preset fails or silently falls back.
# H.264 streams are decoded on CPU here. If you ever switch the cameras to
# H.265, the Pi 5 DOES have an HEVC decoder — use preset-rpi-64-h265 then.

cameras:
  living_room:
    ffmpeg:
      inputs:
        - path: rtsp://127.0.0.1:8554/living_room_sub
          input_args: preset-rtsp-generic
          roles:
            - detect
        - path: rtsp://127.0.0.1:8554/living_room
          input_args: preset-rtsp-generic
          roles:
            - record
    detect:
      enabled: false
      fps: 5
      width: 640
      height: 480
    record:
      enabled: true
      continuous:
        days: 14
      motion:
        days: 0

version: 0.17-0
